# For more information, please refer to documentation: https://learn.microsoft.com/en-us/azure/vpn-gateway/point-to-site-vpn-client-certificate-windows-openvpn-client
client
remote azuregateway-b89b0031-0298-4ee3-807e-1ae3a738ef48-52ff4eb13241.vpn.azure.com 443
verify-x509-name b89b0031-0298-4ee3-807e-1ae3a738ef48.vpn.azure.com name
remote-cert-tls server

disable-dco

dev tun
proto tcp
nobind

# Route Azure VNet traffic through the VPN tunnel
route 10.0.0.0 255.255.0.0 vpn_gateway

auth SHA256
cipher AES-256-GCM

tls-timeout 30
tls-version-min 1.2
key-direction 1

verb 3

ping-restart 0

